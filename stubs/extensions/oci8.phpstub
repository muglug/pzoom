/**
 * @since 8.0
 */
class OCILob
{
    /**
     * @return string|false The contents of the object, or FALSE on errors.
     */
    public function load() {}

    /**
     * @return int|false Current position of a LOB's internal pointer or FALSE if an
     */
    public function tell() {}

    /**
     * @param int $length [optional]
     * @return bool TRUE on success or FALSE on failure.
     */
    public function truncate($length = 0) {}

    /**
     * @param int $offset [optional]
     * @param int $length [optional]
     * @return int|false The actual number of characters/bytes erased or FALSE on failure.
     */
    public function erase($offset = null, $length = null) {}

    /**
     * @param int $flag [optional]
     * @return bool TRUE on success or FALSE on failure.
     */
    public function flush($flag = null) {}

    /**
     * @param bool $on_off
     * @return bool TRUE on success or FALSE on failure. Repeated calls to this method with the same flag will
     */
    public function setbuffering($on_off) {}

    /**
     * @return bool FALSE if buffering for the large object is off and TRUE if
     */
    public function getbuffering() {}

    /**
     * @return bool TRUE on success or FALSE on failure.
     */
    public function rewind() {}

    /**
     * @param int $length
     * @return string|false The contents as a string, or FALSE on failure.
     */
    public function read($length) {}

    /**
     * @return bool TRUE if internal pointer of large object is at the end of LOB.
     */
    public function eof() {}

    /**
     * @param int $offset
     * @param int $whence [optional]
     * @return bool TRUE on success or FALSE on failure.
     */
    public function seek($offset, $whence = OCI_SEEK_SET) {}

    /**
     * @param string $data
     * @param int $length [optional]
     * @return int|false The number of bytes written or FALSE on failure.
     */
    public function write($data, $length = null) {}

    /**
     * @param OCILob $lob_from
     * @return bool TRUE on success or FALSE on failure.
     */
    public function append(OCILob $lob_from) {}

    /**
     * @return int|false Length of large object value or FALSE on failure.
     */
    public function size() {}

    /**
     * @param $filename
     * @param $start [optional]
     * @param $length [optional]
     * @return bool TRUE on success or FALSE on failure.
     */
    public function writetofile($filename, $start, $length) {}

    /**
     * @param string $filename
     * @param int $start [optional]
     * @param int $length [optional]
     * @return bool TRUE on success or FALSE on failure.
     */
    public function export($filename, $start = null, $length = null) {}

    /**
     * @param string $filename
     * @return bool TRUE on success or FALSE on failure.
     */
    public function import($filename) {}

    /**
     * @param string $data
     * @param int $lob_type [optional]
     * @return bool TRUE on success or FALSE on failure.
     */
    public function writeTemporary($data, $lob_type = OCI_TEMP_CLOB) {}

    /**
     * @return bool TRUE on success or FALSE on failure.
     */
    public function close() {}

    /**
     * @param string $data
     * @param int $offset [optional]
     * @return bool TRUE on success or FALSE on failure.
     */
    public function save($data, $offset = null) {}

    /**
     * @param $filename
     * @return bool Return true on success and false on failure
     */
    public function savefile($filename) {}

    /**
     * @return bool TRUE on success or FALSE on failure.
     */
    public function free() {}
}

/**
 * @since 8.0
 */
class OCICollection
{
    /**
     * @param mixed $value
     * @return bool TRUE on success or FALSE on failure.
     */
    public function append($value) {}

    /**
     * @param int $index
     * @return mixed FALSE if such element doesn't exist; NULL if element is NULL;
     */
