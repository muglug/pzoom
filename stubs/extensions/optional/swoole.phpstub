        public $headers;
        public $set_cookie_headers;
        public $cookies;
        public $body = '';

        public function __construct($host, $port = null, $ssl = null) {}

        public function __destruct() {}

        /**
         * @return mixed
         */
        public function set(array $settings) {}

        /**
         * @return mixed
