namespace Relay\Cluster {
    final class FullscanGenerator extends \Generator {}
}

namespace Relay {
    abstract class Event
    {
        /**
         * @var int
         */
        public const INVALIDATED = 1;

        /**
         * @var int
         */
        public const Invalidated = 1;

        /**
         * @var int
         */
        public const FLUSHED = 2;

        /**
         * @var int
         */
        public const Flushed = 2;

        /**
         * @var int
         */
        public int $type;

        /**
         * @var mixed
         */
        public mixed $key = null;

        /**
         * @var bool
         */
        public bool $client;
    }
}

namespace Relay\Event {
    final class Invalidated extends \Relay\Event
    {
        /**
         * @var int
         */
        public int $type = 1;
    }

    final class Flushed extends \Relay\Event
    {
        /**
         * @var int
         */
        public int $type = 2;
    }
}

namespace Relay {
    class Exception extends \Exception {}
}

namespace Relay {
    enum KeyType: int
    {
            case NotFound = Relay::REDIS_NOT_FOUND;

            case String = Relay::REDIS_STRING;

            case Set = Relay::REDIS_SET;

            case List = Relay::REDIS_LIST;

            case Zset = Relay::REDIS_ZSET;

            case Hash = Relay::REDIS_HASH;

            case Stream = Relay::REDIS_STREAM;
    }
}

