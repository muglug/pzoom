    /**
     * @param int $index
     * @param mixed $value
     * @return bool TRUE on success or FALSE on failure.
     */
    public function assignelem($index, $value) {}

    /**
     * @param OCICollection $from
     * @return bool TRUE on success or FALSE on failure.
     */
    public function assign(OCICollection $from) {}

    /**
     * @return int|false The number of elements in the collection or FALSE on error.
     */
    public function size() {}

    /**
     * @return int|false The maximum number as an integer, or FALSE on errors.
     */
    public function max() {}

    /**
     * @param int $num
     * @return bool TRUE on success or FALSE on failure.
     */
    public function trim($num) {}

    /**
     * @return bool TRUE on success or FALSE on failure.
     */
    public function free() {}
}

